{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:default",
    "shell:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "bin/ffmpeg",
          "sidecar": true
        },
        {
          "name": "bin/ffprobe",
          "sidecar": true
        },
        {
          "name": "bin/whisper",
          "sidecar": true
        }
      ]
    }
  ],
  "commands": {
    "allow": [
      "detect_orientation",
      "convert_to_ratio",
      "check_file_ready",
      "release_processing_lock",
      "start_batch",
      "cancel_batch",
      "get_batch_status",
      "clear_batch",
      "get_all_presets",
      "save_preset",
      "delete_preset"
    ]
  }
}
