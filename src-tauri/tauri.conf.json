{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "aspectshift-htov",
  "version": "0.1.0",
  "identifier": "aspectshift-htov",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "aspectshift-htov",
        "width": 1230,
        "height": 690,
        "minWidth": 1230,
        "minHeight": 690,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["bin/ffmpeg", "bin/ffprobe", "bin/whisper"],
    "resources": ["resources/ggml-*.bin"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "dialog": null,
    "updater": {
      "endpoints": [
        "https://releases.yourapp.com/{{target}}/{{arch}}/{{current_version}}"
      ],
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDYxQjc5NjA1N0IwN0FBNUQKUldSZHFnZDdCWmEzWVRGWXprYWp3UFZxRmx1Q21CTENYZzN4eU83L2grOVFJa0ZiV0ZOYTUrUGYK"
    }
  }
}
