{
  "name": "aspectshift-htov",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "gen:types": "node -e \"require('fs').mkdirSync('src/types',{ recursive: true })\" && cargo run --manifest-path src-tauri/Cargo.toml --bin export_types",
    "predev": "npm run gen:types",
    "prebuild": "npm run gen:types",
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev --features dev-auth"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.0.0",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
